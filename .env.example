# ─────────────────────────────────────────────────────────────────
# Frontend (.env for Vite)
# ─────────────────────────────────────────────────────────────────

# API backend URL (adjust for your deployment)
VITE_API_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────
# Backend (.env for FastAPI)
# ─────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bganalysis

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP Configuration (for sending emails)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@bganalysis.com

# Frontend URL (for password reset links, OAuth redirects)
FRONTEND_URL=http://localhost:5173

# API Base URL (for upload response URLs)
BASE_URL=http://localhost:8000

# Stripe (optional, for checkout)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────
# Setup Instructions
# ─────────────────────────────────────────────────────────────────
#
# 1. Copy this file to .env in both the project root and src/backend/
#    cp .env.example .env
#    cp .env.example src/backend/.env
#
# 2. Update values with your own configuration
#
# 3. For Gmail SMTP:
#    - Enable 2FA on your Google account
#    - Generate an App Password: https://myaccount.google.com/apppasswords
#    - Use the app password in SMTP_PASSWORD
#
# 4. For PostgreSQL database:
#    - Install PostgreSQL locally or use a cloud provider (Railway, Heroku, etc)
#    - Create a database: createdb bganalysis
#    - Update DATABASE_URL with your connection string
#
# 5. For JWT_SECRET_KEY:
#    - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 6. For production:
#    - Use strong, random values for all secrets
#    - Store secrets in environment variables, not in .env files
#    - Enable HTTPS
#    - Use a proper email service (SendGrid, AWS SES, etc)
